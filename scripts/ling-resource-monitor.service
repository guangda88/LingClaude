[Unit]
Description=LingClaude Resource Monitor Dashboard
After=network.target

[Service]
Type=simple
User=ai
Group=ai
WorkingDirectory=/home/ai/LingClaude/scripts
Environment="PYTHONPATH=/home/ai/LingClaude"
ExecStart=/usr/bin/python3 /home/ai/LingClaude/scripts/resource_monitor_dashboard.py
Restart=always
RestartSec=10
MemoryMax=512M
CPUQuota=100%
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
